{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agentPushNotifEnabled": true,
  "alwaysThinkingEnabled": true,
  "editorMode": "vim",
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "cheese-design-system@sen-marketplace": true,
    "cloudflare@cloudflare": true,
    "codex@openai-codex": true,
    "figma@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "reviewing-skills@sen-marketplace": true,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "repo": "cloudflare/skills",
        "source": "github"
      }
    },
    "openai-codex": {
      "source": {
        "repo": "openai/codex-plugin-cc",
        "source": "github"
      }
    },
    "sen-marketplace": {
      "source": {
        "repo": "sen-corporation/claude-code-plugins",
        "source": "github"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754061737891
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "herdr notification show 'Claude Code' --body '許可が必要です' --sound request 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "permission_prompt"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/scripts/worktree-sync.sh",
            "type": "command"
          }
        ],
        "matcher": "EnterWorktree|ExitWorktree"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/hanabusa.kotaro/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "input=$(cat); if [ \"$(printf '%s' \"$input\" | jq -r '.stop_hook_active // false')\" = \"true\" ]; then exit 0; fi; herdr notification show 'Claude Code' --body '作業が完了しました' --sound done 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "language": "日本語",
  "model": "claude-fable-5[1m]",
  "permissions": {
    "allow": [
      "Bash(nb:*)",
      "Bash(git:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(curl:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(jq:*)",
      "Bash(rg:*)",
      "Write(~/.nb/**)",
      "Edit(~/.nb/**)",
      "mcp__time__get_current_time"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "preferredNotifChannel": "terminal_bell",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "statusLine": {
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.cwd'); user=$(whoami); host=$(hostname -s); display_dir=\"${cwd/#$HOME/~}\"; git_info=\"\"; if git -C \"$cwd\" rev-parse --git-dir > /dev/null 2>&1; then branch=$(git -C \"$cwd\" --no-optional-locks branch --show-current 2>/dev/null || echo \"\"); if [ -n \"$branch\" ]; then dirty=\"\"; staged=\"\"; untracked=\"\"; if ! git -C \"$cwd\" --no-optional-locks diff --quiet 2>/dev/null; then dirty=\"*\"; fi; if ! git -C \"$cwd\" --no-optional-locks diff --cached --quiet 2>/dev/null; then staged=\"+\"; fi; if [ -n \"$(git -C \"$cwd\" --no-optional-locks ls-files --others --exclude-standard 2>/dev/null)\" ]; then untracked=\"%\"; fi; git_info=\" $(printf '\\033[38;5;208m')($branch$dirty$staged$untracked)$(printf '\\033[0m')\"; fi; fi; printf \"%s@%s $(printf '\\033[34m')%s$(printf '\\033[0m')%s \" \"$user\" \"$host\" \"$display_dir\" \"$git_info\"",
    "type": "command"
  },
  "theme": "light-daltonized",
  "tui": "default"
}